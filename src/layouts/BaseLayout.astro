---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  activeNav?: 'home' | 'threshold' | 'lab' | 'archive' | 'colophon';
}

const {
  title = 'MODUSENSUS',
  description = 'Exploring ideas, technology and human creativity.',
  activeNav = 'home',
} = Astro.props;

const navLinks = [
  { href: '/',               label: 'Home',            key: 'home'      },
  { href: '/threshold-notes', label: 'Threshold Notes', key: 'threshold' },
  { href: '/lab',            label: 'Lab',             key: 'lab'       },
  { href: '/archive',        label: 'Archive',         key: 'archive'   },
  { href: '/colophon',       label: 'Colophon',        key: 'colophon'  },
];
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <ViewTransitions />
</head>
<body>

  <!-- ── Reading progress bar (article pages) ── -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

  <!-- ── Masthead ── -->
  <header class="masthead entrance entrance-1">
    <div class="masthead-center">
      <a href="/" class="masthead-title">MODUSENSUS</a>
    </div>
    <div class="masthead-right">
      <button class="masthead-menu" aria-label="Menu" id="menu-toggle">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- ── Sub-nav bar ── -->
  <nav class="subnav entrance entrance-1">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['subnav-link', { active: activeNav === link.key }]}
      >
        {link.label}
      </a>
    ))}

  </nav>

  <!-- ── Mobile menu ── -->
  <div class="mobile-menu" id="mobile-menu">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['mobile-link', { active: activeNav === link.key }]}
      >
        {link.label}
      </a>
    ))}
  </div>

  <!-- ── Page content ── -->
  <main>
    <slot />
  </main>

  <!-- ── Footer ── -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-copy">&copy; 2026 MODUSENSUS &middot; Independent Digital Studio</span>

    </div>
  </footer>

</body>
</html>

<style>
/* ── Masthead ── */
.masthead {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0.75rem 2rem;
  border-bottom: 1px solid var(--border);
  position: relative;
}
.masthead-right {
  position: absolute;
  right: 2rem;
}
.masthead-center {
  text-align: center;
}
.masthead-location {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--dust);
}
.masthead-title {
  font-family: 'Playfair Display', 'Noto Serif SC', serif;
  font-size: 28px;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--ink);
}
.masthead-menu {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  padding: 4px;
  cursor: pointer;
}
.masthead-menu span {
  display: block;
  width: 20px;
  height: 1.5px;
  background: var(--ink);
}

/* ── Sub-nav ── */
.subnav {
  display: flex;
  justify-content: center;
  gap: 2rem;
  padding: 0.6rem 2rem;
  border-bottom: 1px solid var(--border);
}
.subnav-link {
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--dust);
  transition: color 0.2s;
}
.subnav-link:hover,
.subnav-link.active {
  color: var(--ink);
}

/* ── Mobile menu ── */
.mobile-menu {
  display: none;
  flex-direction: column;
  border-bottom: 1px solid var(--border);
}
.mobile-menu.open { display: flex; }
.mobile-link {
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 1rem 2rem;
  border-bottom: 1px solid var(--border);
  color: var(--dust);
}
.mobile-link.active { color: var(--ink); }

/* ── Footer ── */
.footer {
  border-top: 1px solid var(--border);
  margin-top: auto;
}
.footer-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 2rem;
}
.footer-copy {
  font-family: var(--font-ui);
  font-size: 10px;
  color: var(--dust);
  letter-spacing: 0.06em;
}


/* ── Responsive ── */
@media (max-width: 768px) {
  .masthead { padding: 0.75rem 1.25rem; }
  .masthead-right { right: 1.25rem; }
  .masthead-title { font-size: 22px; }
  .masthead-menu { display: flex; }
  .subnav {
    display: none;
  }
  .footer-inner { padding: 1rem 1.25rem; }
}
</style>

<script>
// ── Mobile menu toggle ──
function initMenu() {
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
}

// ── Scroll reveal observer (fade-in + reveal + reveal-stagger) ──
function initReveal() {
  const els = document.querySelectorAll('.fade-in, .reveal, .reveal-stagger');
  if (!els.length) return;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) {
    els.forEach(el => el.classList.add('visible'));
    return;
  }
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  els.forEach(el => obs.observe(el));
}

// ── Reading progress bar (article pages) ──
function initReadingProgress() {
  const bar = document.getElementById('reading-progress');
  if (!bar) return;
  const article = document.querySelector('article.article') || document.body;
  const update = () => {
    const rect = article.getBoundingClientRect();
    const total = rect.height - window.innerHeight;
    const scrolled = Math.max(0, -rect.top);
    const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
    bar.style.width = pct + '%';
    bar.style.opacity = pct > 0 && pct < 100 ? '1' : '0';
  };
  window.addEventListener('scroll', update, { passive: true });
  update();
}

// ── Parallax (subtle magazine depth) ──
function initParallax() {
  const els = document.querySelectorAll('.parallax');
  if (!els.length) return;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) return;
  let ticking = false;
  const update = () => {
    els.forEach(el => {
      const rect = el.getBoundingClientRect();
      const vh = window.innerHeight;
      if (rect.bottom < 0 || rect.top > vh) return;
      const offset = (rect.top + rect.height / 2 - vh / 2) / vh;
      el.style.transform = `translateY(${(-offset * 12).toFixed(2)}px)`;
    });
    ticking = false;
  };
  window.addEventListener('scroll', () => {
    if (!ticking) { requestAnimationFrame(update); ticking = true; }
  }, { passive: true });
  update();
}

// ── Initialize on load + View Transitions ──
function initAll() {
  initMenu();
  initReveal();
  initReadingProgress();
  initParallax();
}
initAll();
document.addEventListener('astro:after-swap', initAll);
</script>
