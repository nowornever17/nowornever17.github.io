---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    name: 'CaseForge',
    desc: '学术论文深度拆解框架。8 字段结构化提取 + 4 格式输出，多学科 Prompt 插件化，3 大论文库聚合搜索。',
    stack: ['Python', 'DeepSeek', 'LLM', 'OpenAlex'],
    status: 'v2.0',
    href: 'https://github.com/modusensus/CaseForge',
  },
  {
    name: 'MindOS',
    desc: 'AI 驱动的个人成长系统。8 模块单文件 HTML Widget，支持多 AI 提供商，语音输入，AI 教练监督。',
    stack: ['HTML/CSS/JS', 'Multi-AI', 'Claude Artifacts'],
    status: 'Active',
    href: 'https://github.com/modusensus/Mindos',
  },
  {
    name: 'Delpine Blog',
    desc: '个人博客与作品集网站。Astro + Editorial Brutalism 风格，GitHub Pages 部署。',
    stack: ['Astro', 'HTML/CSS', 'GitHub Pages'],
    status: 'v1.0',
    href: 'https://github.com/modusensus/modusensus.github.io',
  },
];
---

<BaseLayout title="Projects · modusensus" activeNav="projects">

  <div class="page-header">
    <h1 class="page-title">PROJECTS.</h1>
    <p class="page-sub">城市设计 · 自动化工具 · AI 应用实践</p>
  </div>

  <div class="projects-list">
    {projects.map((p, i) => (
      <a
        href={p.href}
        target="_blank"
        rel="noopener noreferrer"
        class="proj-row"
      >
        <div class="proj-index">0{i + 1}</div>
        <div class="proj-body">
          <h2 class="proj-name">{p.name}</h2>
          <p class="proj-desc">{p.desc}</p>
          <div class="proj-stack">
            {p.stack.map(s => <span class="pill">{s}</span>)}
          </div>
        </div>
        <div class="proj-right">
          <span class:list={['proj-status', p.status === 'Completed' ? 'status-done' : 'status-wip']}>
            {p.status}
          </span>
          <span class="proj-arrow">↗</span>
        </div>
      </a>
    ))}
  </div>

</BaseLayout>

<style>
.page-header {
  padding: 2rem 2rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.page-title {
  font-family: var(--font-display);
  font-size: clamp(40px, 8vw, 64px);
  letter-spacing: 0.04em;
  line-height: 1;
}
.page-sub {
  font-family: var(--font-ui);
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 0.5rem;
}

/* Project rows */
.projects-list { padding: 0 2rem; }
.proj-row {
  display: grid;
  grid-template-columns: 48px 1fr auto;
  gap: 1.5rem;
  align-items: start;
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}
.proj-row:hover .proj-name { color: var(--olive); }

.proj-index {
  font-family: var(--font-display);
  font-size: 32px;
  color: var(--border-strong);
  line-height: 1.1;
  padding-top: 2px;
}
.proj-name {
  font-family: var(--font-display);
  font-size: 28px;
  letter-spacing: 0.04em;
  line-height: 1;
  transition: color 0.2s;
  margin-bottom: 6px;
}
.proj-desc {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.6;
}
.proj-stack {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  margin-top: 10px;
}
.proj-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.5rem;
  padding-top: 4px;
}
.proj-status {
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 2px;
  white-space: nowrap;
}
.status-done { background: var(--ink); color: var(--bg); }
.status-wip  { background: var(--olive-bg); color: var(--olive-text); }
.proj-arrow {
  font-size: 18px;
  color: var(--muted);
  transition: color 0.2s, transform 0.2s;
}
.proj-row:hover .proj-arrow {
  color: var(--olive);
  transform: translate(2px, -2px);
}

/* Responsive */
@media (max-width: 640px) {
  .page-header,
  .projects-list { padding-left: 1.25rem; padding-right: 1.25rem; }
  .proj-row { grid-template-columns: 36px 1fr; }
  .proj-right { display: none; }
}
</style>
