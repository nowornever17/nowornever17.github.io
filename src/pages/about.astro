---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About · Novum" activeNav="about">

  <div class="about-grid">

    <!-- Left: Big text + intro -->
    <div class="about-left">
      <h1 class="about-title">
        ABOUT<br /><span class="olive">NOVUM.</span>
      </h1>
      <p class="about-desc">
        城乡规划专业五年级本科生，正在准备跨考电子科技大学公共管理学硕。
        长期对城市空间、数字治理与 AI 工具实践保持热情，目标是将规划背景与公共政策研究结合，
        走向数字治理领域的学术研究路径。
      </p>
      <div class="about-tags">
        <span class="about-tag">城乡规划</span>
        <span class="about-tag">公共管理</span>
        <span class="about-tag">数字治理</span>
        <span class="about-tag">AI 工具</span>
        <span class="about-tag">INTJ</span>
      </div>
    </div>

    <!-- Right: Details -->
    <div class="about-right">

      <div class="detail-section">
        <h2 class="detail-title">Education</h2>
        <div class="detail-item">
          <strong>城乡规划（工学）</strong><br />
          某工科高校 · 2021–2026（在读）
        </div>
        <div class="detail-item" style="margin-top: 0.6rem;">
          <strong>目标：公共管理学硕</strong><br />
          电子科技大学 · 2026 考研
        </div>
      </div>

      <div class="detail-section">
        <h2 class="detail-title">Research Interests</h2>
        <ul class="detail-list">
          <li>空间公平与城市可达性</li>
          <li>数字治理与 AI 政策</li>
          <li>公共服务设施布局优化</li>
          <li>人机协作与自动化工作流</li>
        </ul>
      </div>

      <div class="detail-section">
        <h2 class="detail-title">Tech Stack</h2>
        <div class="stack-row">
          {['Python', 'GIS', 'n8n', 'React', 'TypeScript', 'Tauri', 'SQLite', 'Obsidian', 'DeepSeek API'].map(s => (
            <span class="pill">{s}</span>
          ))}
        </div>
      </div>

      <div class="detail-section">
        <h2 class="detail-title">Subscribe</h2>
        <p style="font-size:13px;color:var(--muted);margin-bottom:12px;line-height:1.7">
          Get notified when I publish new articles. No spam, unsubscribe anytime.
        </p>
        <form action="https://buttondown.email/api/emails/embed-subscribe/your-username" method="post" target="_blank" class="subscribe-form">
          <input type="email" name="email" placeholder="your@email.com" required class="subscribe-input">
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </form>
        <p style="font-size:11px;color:var(--muted);margin-top:8px">
          Powered by Buttondown · <a href="https://buttondown.email" style="color:var(--olive)">Set up for free</a>
        </p>
      </div>

      <div class="detail-section">
        <h2 class="detail-title">Contact</h2>
        <div class="contact-row">
          <a href="https://github.com/modusensus" target="_blank" class="contact-btn olive">
            GitHub
          </a>
          <a href="mailto:1668531760@qq.com" class="contact-btn">
            Email
          </a>
          <a href="https://www.xiaohongshu.com/user/profile/6319d2dd0000000023027b2a" target="_blank" class="contact-btn">
            小红书
          </a>
        </div>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: calc(100vh - 120px);
}

/* Left */
.about-left {
  padding: 2.5rem 2rem;
  border-right: 1px solid var(--border);
}
.about-title {
  font-family: var(--font-display);
  font-size: clamp(52px, 9vw, 80px);
  line-height: 0.88;
  letter-spacing: 0.02em;
}
.olive { color: var(--olive); }
.about-desc {
  font-size: 13px;
  line-height: 1.85;
  color: var(--muted);
  margin-top: 1.4rem;
  max-width: 380px;
}
.about-tags {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 1.4rem;
}
.about-tag {
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 4px 10px;
  border: 0.5px solid var(--border-strong);
  border-radius: 2px;
  color: var(--muted);
}

/* Right */
.about-right {
  padding: 2.5rem 2rem;
}
.detail-section {
  margin-bottom: 2rem;
}
.detail-title {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 0.75rem;
  padding-bottom: 0.5rem;
  border-bottom: 0.5px solid var(--border);
}
.detail-item {
  font-size: 13px;
  color: var(--muted);
  line-height: 1.7;
}
.detail-item strong { color: var(--ink); font-weight: 500; }

.detail-list {
  list-style: none;
  padding: 0;
}
.detail-list li {
  font-size: 13px;
  color: var(--muted);
  padding: 3px 0;
  padding-left: 1rem;
  position: relative;
}
.detail-list li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--olive);
  font-size: 11px;
}

.stack-row {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}

/* Subscribe form */
.subscribe-form {
  display: flex;
  gap: 8px;
  max-width: 360px;
}
.subscribe-input {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid var(--border-strong);
  background: var(--bg);
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--ink);
  outline: none;
  border-radius: 2px;
}
.subscribe-input:focus { border-color: var(--olive); }
.subscribe-btn {
  padding: 8px 16px;
  background: var(--ink);
  color: var(--bg);
  border: none;
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  border-radius: 2px;
  transition: opacity 0.2s;
}
.subscribe-btn:hover { opacity: 0.8; }

/* Contact buttons */
.contact-row {
  display: flex;
  gap: 0.6rem;
  flex-wrap: wrap;
  margin-top: 0.25rem;
}
.contact-btn {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 6px 14px;
  border: 1px solid var(--ink);
  background: transparent;
  color: var(--ink);
  border-radius: 2px;
  transition: all 0.15s;
  display: inline-block;
}
.contact-btn:hover {
  background: var(--ink);
  color: var(--bg);
}
.contact-btn.olive {
  border-color: var(--olive);
  color: var(--olive);
}
.contact-btn.olive:hover {
  background: var(--olive);
  color: #fff;
}

/* Responsive */
@media (max-width: 768px) {
  .about-grid {
    grid-template-columns: 1fr;
  }
  .about-left {
    border-right: none;
    border-bottom: 1px solid var(--border);
    padding: 2rem 1.25rem;
  }
  .about-right { padding: 1.5rem 1.25rem; }
}
</style>
