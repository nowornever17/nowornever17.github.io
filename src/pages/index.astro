---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const tagClass: Record<string, string> = {
  '学习成长': 'tag-study',
  '项目日志': 'tag-proj',
  '阈值笔记': 'tag-think',
};

const projects = [
  {
    name: 'CaseForge',
    desc: '学术论文深度拆解框架。8 字段提取 + 4 格式输出，多学科 Prompt 插件化。',
    stack: ['Python', 'DeepSeek', 'LLM'],
    href: 'https://github.com/modusensus/CaseForge',
  },
  {
    name: 'govdaily-skill',
    desc: '考研公管日报自动生成与推送。AI 每日考点+时政+易错提醒，Obsidian 同步。',
    stack: ['Python', 'DeepSeek', 'Claude Code'],
    href: 'https://github.com/modusensus/govdaily-skill',
  },
];
---

<BaseLayout activeNav="home">

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow">Urban Planning × Digital Governance × AI Tools</p>
      <h1 class="hero-title">
        新序<br /><span class="olive">NOVUM.</span>
      </h1>
      <p class="hero-desc">
        城乡规划本科在读，备考 UESTC 公共管理学硕。<br />
        关注空间公平、数字治理与 AI 工具实践。
      </p>
    </div>
    <div class="hero-meta">2026 · CHENGDU · CHINA</div>
  </section>

  <!-- ── Latest Posts ── -->
  <section>
    <div class="section-header">
      <span class="section-label">LATEST POSTS</span>
      <a href="/blog" class="section-link">All posts →</a>
    </div>

    <div class="posts-list">
      {latestPosts.map((post, i) => (
        <a href={post.data.redirect || `/blog/${post.slug}`} class="post-row">
          <span class="post-num">0{i + 1}</span>
          <div class="post-body">
            <p class="post-title">{post.data.title}</p>
            <p class="post-sub">{post.data.excerpt}</p>
          </div>
          <span class={`tag ${tagClass[post.data.tag] ?? 'tag-think'}`}>
            {post.data.tag}
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── Featured Projects ── -->
  <section>
    <div class="section-header">
      <span class="section-label">PROJECTS</span>
      <a href="/projects" class="section-link">All projects →</a>
    </div>

    <div class="proj-grid">
      {projects.map(p => (
        <a href={p.href} target="_blank" rel="noopener" class="proj-card">
          <p class="proj-name">{p.name}</p>
          <p class="proj-desc">{p.desc}</p>
          <div class="proj-stack">
            {p.stack.map(s => <span class="pill">{s}</span>)}
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
/* Hero */
.hero {
  padding: 3rem 2rem 2rem;
  border-bottom: 1px solid var(--border);
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 2rem;
  align-items: end;
}
.eyebrow {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--olive);
  margin-bottom: 1rem;
}
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(56px, 12vw, 96px);
  line-height: 0.88;
  letter-spacing: 0.02em;
}
.olive { color: var(--olive); }
.hero-desc {
  margin-top: 1.2rem;
  font-size: 14px;
  line-height: 1.8;
  color: var(--muted);
  max-width: 420px;
}
.hero-meta {
  font-family: var(--font-ui);
  font-size: 11px;
  color: var(--muted);
  letter-spacing: 0.08em;
  writing-mode: vertical-rl;
  text-orientation: mixed;
  transform: rotate(180deg);
  align-self: stretch;
  display: flex;
  align-items: center;
}

/* Section chrome */
.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 1.2rem 2rem 0.8rem;
  border-bottom: 1px solid var(--border);
}
.section-label {
  font-family: var(--font-display);
  font-size: 28px;
  letter-spacing: 0.04em;
}
.section-link {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  transition: color 0.2s;
}
.section-link:hover { color: var(--olive); }

/* Post rows */
.posts-list { padding: 0 2rem; }
.post-row {
  display: grid;
  grid-template-columns: 48px 1fr auto;
  gap: 1rem;
  align-items: center;
  padding: 1rem 0;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}
.post-row:hover .post-title { color: var(--olive); }
.post-num {
  font-family: var(--font-display);
  font-size: 36px;
  color: var(--border-strong);
  line-height: 1;
}
.post-title {
  font-family: var(--font-ui);
  font-size: 16px;
  font-weight: 700;
  transition: color 0.2s;
}
.post-sub {
  font-size: 13px;
  color: var(--muted);
  margin-top: 2px;
}

/* Project grid */
.proj-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--border);
}
.proj-card {
  background: var(--bg);
  padding: 1.4rem;
  transition: background 0.15s;
  display: block;
}
.proj-card:hover { background: rgba(107,124,74,0.06); }
.proj-name {
  font-family: var(--font-display);
  font-size: 24px;
  letter-spacing: 0.04em;
}
.proj-desc {
  font-size: 12px;
  color: var(--muted);
  margin-top: 4px;
  line-height: 1.6;
}
.proj-stack {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  margin-top: 10px;
}

/* Responsive */
@media (max-width: 640px) {
  .hero {
    grid-template-columns: 1fr;
    padding: 2rem 1.25rem;
  }
  .hero-meta { display: none; }
  .section-header,
  .posts-list { padding-left: 1.25rem; padding-right: 1.25rem; }
  .proj-grid { grid-template-columns: 1fr; }
  .proj-card { padding: 1.2rem 1.25rem; }
  .post-row { grid-template-columns: 36px 1fr; }
  .post-row .tag { display: none; }
}
</style>
